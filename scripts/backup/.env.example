# MAAL Backup env — copy to .env on VPS, NEVER commit real values
# Location on VPS: /home/deploy/maal-backup/.env

# Direct Postgres connection (NOT pgbouncer pool — pg_dump needs direct).
# Get from Supabase dashboard → Database → Connection string → "Direct connection".
# Format: postgresql://postgres:PASSWORD@db.saecuecevicwjkpmaoot.supabase.co:5432/postgres
DATABASE_URL=

# GPG public key id or email for encryption.
# Generated keypair: see scripts/backup/README.md §1.
# Public key imported on VPS via gpg --import.
GPG_RECIPIENT=backup@mpstats.academy

# nikear via Tailscale (VPS ~/.ssh/config should have host alias + ProxyJump set up).
NIKEAR_SSH_HOST=
NIKEAR_SSH_USER=
NIKEAR_BACKUP_DIR=/home/zebrosha/backups/maal

# How long to keep backups on nikear (days). Older files auto-deleted at end of run.
RETENTION_DAYS=30

# Optional — Telegram alerts on failure via Vai bot (@ZebroPersonalBot).
# Token + chat id in OpenClaw config or local secrets.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=378833288
